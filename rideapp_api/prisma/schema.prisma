generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  phone    String? 
  role     String // client, driver
  status   String // idle, searching, on_trip
  trips    Trip[] @relation("ClientTrips")
}

model Driver {
  id              String   @id @default(uuid())
  vehicleDetails  Json
  currentLocation Unsupported("geometry(Point, 4326)")
  rating          Float
  isVerified      Boolean  @default(false)
  isOnline        Boolean  @default(false)
  trips           Trip[]   @relation("DriverTrips")
}

model Trip {
  id        String   @id @default(uuid())
  clientId  String
  client    User     @relation("ClientTrips", fields: [clientId], references: [id])
  driverId  String?
  driver    Driver?  @relation("DriverTrips", fields: [driverId], references: [id])
  status    String   // requested, accepted, inProgress, completed, cancelled
  route     Unsupported("geometry(LineString, 4326)")?
}

model LocationRecord {
  id        String   @id @default(uuid())
  entityId  String
  coords    Unsupported("geometry(Point, 4326)")
  heading   Float
  speed     Float
  timestamp BigInt
}

model NegotiationOffer {
  id            String   @id @default(uuid())
  tripId        String
  driverId      String
  offeredPrice  Float
  counterPrice  Float?
  status        String   // pending, counter, accepted, rejected, cancelled
  createdAt     DateTime @default(now())
}

model Rating {
  id          String   @id @default(uuid())
  tripId      String
  ratedBy     String   // passenger | driver
  ratedUserId String   
  rating      Int      
  comment     String?  
  createdAt   DateTime @default(now())
}
