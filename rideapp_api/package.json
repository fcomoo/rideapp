{
  "name": "rideapp_api",
  "version": "1.0.0",
  "description": "RideApp Backend with Fastify, Redis and Prisma",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npx prisma migrate deploy && node dist/index.js",
