    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.2.0",
    "@prisma/client": "^5.10.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "prisma": "^5.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.20"
  }
